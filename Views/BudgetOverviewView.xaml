<UserControl x:Class="FinancialCalculator.Views.BudgetOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:FinancialCalculator.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="16,10">
                <TextBlock Text="Budget Overview" FontSize="20" FontWeight="SemiBold"/>
            </Border>

            <!-- Budget list -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <ItemsControl ItemsSource="{Binding Budgets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10" Padding="14,10">
                                <StackPanel>
                                    <!-- Budget summary row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding BudgetName}" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Foreground="#888" FontSize="12">
                                                <Run Text="{Binding BudgetType}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding AccountName}"/>
                                                <Run Text=" ("/>
                                                <Run Text="{Binding InstitutionName}"/>
                                                <Run Text=")"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Balance" Foreground="#888" FontSize="11"/>
                                            <TextBlock Text="{Binding CurrentBalance, StringFormat=c}" FontSize="16" FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <Button Grid.Column="3" Content="+ Spend" Padding="10,5" VerticalAlignment="Center"
                                                Command="{Binding OpenTransactionFormCommand}"/>
                                    </Grid>

                                    <!-- Inline spend form -->
                                    <Border Visibility="{Binding IsTransactionFormOpen, Converter={StaticResource BoolToVis}}"
                                            Margin="0,8,0,0" Background="#FAFAFA" BorderBrush="#EEE" BorderThickness="1" Padding="10,8" CornerRadius="3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Amount: $" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBox Text="{Binding TransactionAmount, UpdateSourceTrigger=PropertyChanged}"
                                                     Grid.Column="1" Padding="4,2"/>

                                            <TextBlock Text="Description:" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,4,0"/>
                                            <TextBox Text="{Binding TransactionDescription, UpdateSourceTrigger=PropertyChanged}"
                                                     Grid.Column="3" Padding="4,2" Margin="0,0,8,0"/>

                                            <StackPanel Orientation="Horizontal" Grid.Column="4">
                                                <Button Content="Record" Padding="8,3" Margin="0,0,4,0"
                                                        Command="{Binding RecordSpendingCommand}"/>
                                                <Button Content="Cancel" Padding="8,3"
                                                        Command="{Binding CancelTransactionCommand}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
