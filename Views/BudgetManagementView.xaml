<UserControl x:Class="FinancialCalculator.Views.BudgetManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ResourceDictionaries/BudgetEditPanelDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <!-- Main content -->
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="12,8">
                <DockPanel>
                    <TextBlock Text="Budget Management" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="+ Add Budget" HorizontalAlignment="Right" Padding="10,4"
                            Command="{Binding OpenAddFormCommand}"/>
                </DockPanel>
            </Border>

            <!-- Add budget form -->
            <Border DockPanel.Dock="Top" Background="#FFFBE6" BorderBrush="#FFCC00" BorderThickness="0,0,0,1" Padding="12,8"
                    Visibility="{Binding IsAddFormOpen, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="New Budget" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Name:" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding NewBudgetName, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Column="1" Padding="4,2"/>

                        <TextBlock Text="Type:" Grid.Column="2" VerticalAlignment="Center" Margin="12,0,8,0"/>
                        <ComboBox ItemsSource="{Binding BudgetTypes}" SelectedItem="{Binding SelectedBudgetType}"
                                  Grid.Column="3"/>

                        <TextBlock Text="Account:" Grid.Column="4" VerticalAlignment="Center" Margin="12,0,8,0"/>
                        <ComboBox ItemsSource="{Binding AvailableAccounts}" SelectedItem="{Binding SelectedAccount}"
                                  DisplayMemberPath="AccountName" Grid.Column="5"/>

                        <StackPanel Orientation="Horizontal" Grid.Column="6" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="Create" Padding="10,4" Margin="8,0,4,0"
                                    Command="{Binding ConfirmAddBudgetCommand}"/>
                            <Button Content="Cancel" Padding="10,4"
                                    Command="{Binding CancelAddFormCommand}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Budget list -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Column headers -->
                    <Border Background="#E8E8E8" Padding="12,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Name" FontWeight="SemiBold" Grid.Column="0"/>
                            <TextBlock Text="Type" FontWeight="SemiBold" Grid.Column="1"/>
                            <TextBlock Text="Priority" FontWeight="SemiBold" Grid.Column="2"/>
                            <TextBlock Text="Balance" FontWeight="SemiBold" Grid.Column="3"/>
                            <TextBlock Text="Account" FontWeight="SemiBold" Grid.Column="4"/>
                            <TextBlock Text="Actions" FontWeight="SemiBold" Grid.Column="5"/>
                        </Grid>
                    </Border>

                    <!-- Budget rows -->
                    <ItemsControl ItemsSource="{Binding Budgets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding BudgetName}" Grid.Column="0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding BudgetType}" Grid.Column="1" VerticalAlignment="Center" Foreground="#555"/>
                                        <TextBlock Text="{Binding SelectedBudgetPriority}" Grid.Column="2" VerticalAlignment="Center" Foreground="#555"/>
                                        <TextBlock Text="{Binding CurrentBalance, StringFormat=c}" Grid.Column="3" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding AssociatedFinancialAccountName}" Grid.Column="4" VerticalAlignment="Center" Foreground="#555"/>

                                        <StackPanel Orientation="Horizontal" Grid.Column="5" VerticalAlignment="Center">
                                            <Button Content="Edit" Padding="6,2" Margin="0,0,4,0"
                                                    Command="{Binding DataContext.EditBudgetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding BudgetID}"/>
                                            <Button Content="Del" Padding="6,2"
                                                    Command="{Binding DataContext.DeleteBudgetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding BudgetID}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- Edit panel overlay -->
        <Grid Visibility="{Binding IsEditPanelOpen, Converter={StaticResource BoolToVis}}">
            <Rectangle Fill="#88000000"/>
            <Border Background="White" Width="420" MaxHeight="600"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4" Padding="20">
                <StackPanel>
                    <ContentControl Content="{Binding CurrentlyEditingBudget}"
                                    ContentTemplate="{StaticResource BaseBudget_EditPanelTemplate}"/>
                    <Button Content="Save &amp; Close" HorizontalAlignment="Right" Padding="12,5" Margin="0,16,0,0"
                            Command="{Binding CloseEditMenuCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
