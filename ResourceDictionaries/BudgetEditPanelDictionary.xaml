<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:FinancialCalculator.ResourceDictionaries"
                    xmlns:usercontrols="clr-namespace:FinancialCalculator.Controls"
                    xmlns:converters="clr-namespace:FinancialCalculator.Converters">

    <local:BudgetEditPanelTemplateSelector x:Key="BudgetEditPanelTemplateSelector"/>
    <usercontrols:AmtOrPctSetter x:Key="AmtOrPctSetter"/>
    <converters:PercentConverter x:Key="PercentConverter"/>
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

    <DataTemplate x:Key="BaseBudget_EditPanelTemplate">

        <StackPanel Orientation="Vertical" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">

            <TextBlock Text="{Binding BudgetName}" FontSize="20" HorizontalAlignment="Left"/>

            
            
            <StackPanel Orientation="Horizontal" Margin="5, 10, 0, 0">
                <TextBlock Text="Budget Type:" Margin="0, 0, 5, 0"/>
                <TextBlock Text="{Binding BudgetType}"/>
            </StackPanel>


            <StackPanel Orientation="Horizontal" Margin="5, 0, 0, 0">
                <TextBlock Text="Associated Financial Account: " Margin="0, 0, 5, 0"/>
                <TextBlock Text="{Binding AssociatedFinancialAccountName}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5, 5, 0, 0">
                <TextBlock Text="Budget Balance:"/>
                <TextBlock Text="{Binding CurrentBalance, StringFormat='c'}" Margin="5, 0, 0, 0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5, 5, 0, 0">
                <TextBlock Text="Priority:" VerticalAlignment="Center"/>
                <ComboBox SelectedItem="{Binding SelectedBudgetPriority}" ItemsSource="{Binding BudgetPriorities}" Width="150" Margin="5, 0, 0, 0"/>
            </StackPanel>

            <ContentControl Content="{Binding}" ContentTemplateSelector="{StaticResource BudgetEditPanelTemplateSelector}" Margin="0, 15, 0, 0"/>

        </StackPanel>

    </DataTemplate>

    <DataTemplate x:Key="FixedBudget_EditPanelTemplate">

        <StackPanel Orientation="Vertical" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">

            <usercontrols:AmtOrPctSetter 
                TitleText="Monthly Amount:" 
                IsSetByAmt="{Binding IsSetByAmt, Mode=TwoWay}" 
                SetAmount="{Binding SetDepositAmt, Mode=TwoWay}" 
                SetPercent="{Binding SetDepositPct, Mode=TwoWay}"
                />
            
            
            
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="FlexibleBudget_EditPanelTemplate">

        <StackPanel Orientation="Vertical" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="0, 5, 0, 0">
            <GroupBox Header="Minimum Contribution">
                <StackPanel Margin="5">

                    <CheckBox Content="Enable Minimum Amount" IsChecked="{Binding IsMinAmountEnabled}"/>
                    <TextBox Text="{Binding MinAmount, StringFormat='c', UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{Binding IsMinAmountEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
                             Margin="20, 4, 0, 0" Width="140"/>

                    <CheckBox Content="Enable Minimum Percent" IsChecked="{Binding IsMinPercentEnabled}" Margin="0, 10, 0, 0"/>
                    <TextBox Text="{Binding MinPercent, Converter={StaticResource PercentConverter}, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{Binding IsMinPercentEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
                             Margin="20, 4, 0, 0" Width="140"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Maximum Contribution" Margin="0, 10, 0, 0">
                <StackPanel Margin="5">
                    <CheckBox Content="Enable Maximum Amount" IsChecked="{Binding IsMaxAmountEnabled}"/>
                    <TextBox Text="{Binding MaxAmount, StringFormat='c', UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{Binding IsMaxAmountEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
                             Margin="20, 4, 0, 0" Width="140"/>

                    <CheckBox Content="Enable Maximum Percent" IsChecked="{Binding IsMaxPercentEnabled}" Margin="0, 10, 0, 0"/>
                    <TextBox Text="{Binding MaxPercent, Converter={StaticResource PercentConverter}, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{Binding IsMaxPercentEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
                             Margin="20, 4, 0, 0" Width="140"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
        
        
    </DataTemplate>

    <DataTemplate x:Key="SavingsBudget_EditPanelTemplate">

        <StackPanel Orientation="Vertical" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">

            <GroupBox Header="Savings Goal" Margin="0, 15, 0, 0">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Goal Amount" Grid.Row="0" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding GoalAmount, StringFormat='c', UpdateSourceTrigger=PropertyChanged}"
                             Grid.Row="0" Grid.Column="1" Width="150"/>

                    <TextBlock Text="Goal Date" Grid.Row="1" Grid.Column="0" Margin="0,10,10,0" VerticalAlignment="Center"/>
                    <DatePicker SelectedDate="{Binding GoalDate, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Width="150"/>

                    <TextBlock Text="{Binding CalculatedAmtPerMonth, StringFormat='Necessary Amount Per Month: {0:c}'}" Grid.Row="2" Grid.Column="1" Margin="0,10,10,0" VerticalAlignment="Center"/>
                </Grid>
            </GroupBox>

        </StackPanel>

    </DataTemplate>

    <DataTemplate x:Key="RecurringExpenseBudget_EditPanelTemplate">
        <StackPanel Orientation="Vertical" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <GroupBox Header="Recurring Expense Details" Margin="0, 15, 0, 0">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Expense Amount" Grid.Row="0" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding ExpenseAmount, StringFormat='c', UpdateSourceTrigger=PropertyChanged}"
                             Grid.Row="0" Grid.Column="1" Width="150"/>

                    <TextBlock Text="Frequency" Grid.Row="1" Grid.Column="0" Margin="0,10,10,0" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
                        <TextBox Text="{Binding FrequencyValue, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                        <ComboBox ItemsSource="{Binding FrequencyTypes}"
                                  SelectedItem="{Binding SelectedFrequencyType}"
                                  Width="140" Margin="10,0,0,0"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </StackPanel>
    </DataTemplate>
    
</ResourceDictionary>